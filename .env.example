# ---------------------------------------------------------------------------
# ai-engineering-metrics configuration
# Copy this file to ".env" and fill in the values. Never commit your real .env.
# ---------------------------------------------------------------------------

# Run without calling JIRA/GitHub at all (uses realistic fake data).
# Equivalent to passing --mock on the CLI.
MOCK_MODE=false

# ----------------------------- JIRA ----------------------------------------
JIRA_BASE_URL=https://your-company.atlassian.net
JIRA_EMAIL=you@your-company.com
JIRA_API_TOKEN=

# Custom field ids (find them at /rest/api/3/field). Example: customfield_10014
JIRA_EPIC_LINK_FIELD=customfield_10014
JIRA_AI_TOKENS_FIELD=customfield_10100
JIRA_ESTIMATE_WITHOUT_AI_FIELD=customfield_10101
JIRA_ESTIMATE_WITH_AI_FIELD=customfield_10102
JIRA_STORY_POINTS_FIELD=customfield_10016

# ----------------------------- GitHub --------------------------------------
# Authentication uses the GitHub CLI (no token here). Install gh from
# https://cli.github.com and run `gh auth login` once.
#
# These are OPTIONAL: if left blank, the tool auto-detects the repo from the
# git remote of the directory you run it in (machine-CLI style). You can also
# pass --repo owner/name on the command line to override.
GITHUB_ORG=
# Comma separated list of repositories (without org prefix), used when
# GITHUB_SEARCH_ALL_REPOS=false. Example: api,web,workers
GITHUB_REPOSITORIES=
GITHUB_SEARCH_ALL_REPOS=true

# ----------------------------- Pricing -------------------------------------
# Prices are per 1,000,000 tokens.
AI_TOKEN_PRICE_INPUT_PER_1M=3.00
AI_TOKEN_PRICE_OUTPUT_PER_1M=15.00
# Blended price used when the input/output split is unknown.
DEFAULT_TOKEN_PRICE_PER_1M=6.00

# --------------------------- Estimation ------------------------------------
# Used to compute "hours saved" when JIRA has no with/without-AI estimate
# fields: without-AI hours = story_points * STORY_POINT_HOURS;
# with-AI hours = without-AI * (1 - AI_SAVINGS_PERCENT/100).
STORY_POINT_HOURS=1.0
AI_SAVINGS_PERCENT=40.0

# Optional DEMO ONLY: simulate PR review/rework signals (reviews, requested
# changes, commits-after-review, reverts, time-to-merge) that can't be produced
# for real (GitHub blocks self-review). JSON keyed by PR number or "repo#number".
# Leave blank in real usage.
PR_SIMULATION_FILE=

# ----------------------------- Quality -------------------------------------
# Optional path to a JSON file with static-analysis quality metrics.
# If omitted, quality metrics are treated as unavailable (or mocked in mock mode).
QUALITY_METRICS_FILE=
